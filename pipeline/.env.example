# Clé API map-making.app
MMA_API_KEY=

# ID de la map map-making.app (pour upload)
MMA_MAP_ID=

# Source des données: local, remote, auto
# local = utiliser coordinatesAllTags.json local
# remote = télécharger depuis https://www.laliguegeoguessr.fr/tools/coordinatesAllTags.json
# auto = local si existe, sinon remote
SOURCE=auto

# Niveau de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Mode watch: relancer si changement détecté
WATCH_ENABLED=false
WATCH_DEBOUNCE_SECONDS=5

# Validation et traitement
VALIDATE_COORDINATES=true
SKIP_DUPLICATES=true

# Upload automatique après transformation
AUTO_UPLOAD=false

# Mode dry-run: ne pas modifier les fichiers
DRY_RUN=false

# Mode verbose
VERBOSE=false

# Timeouts
DOWNLOAD_TIMEOUT=30
DOWNLOAD_RETRIES=3
